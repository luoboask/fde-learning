_position":4},"sidebar":"tutorialSidebar","previous":{"title":"容量规划","permalink":"/08-cost-operations/capacity-planning"},"next":{"title":"Agent 系统与架构","permalink":"/07-agent-architecture/"}},{"id":"09-evaluation-frontier/fp8-inference","title":"FP8 推理","description":"H100 原生支持 FP8 Tensor Core，在精度损失 < 1% 的前提下实现 1.5-2x 推理加速。","source":"@site/docs/09-evaluation-frontier/fp8-inference.md","sourceDirName":"09-evaluation-frontier","slug":"/09-evaluation-frontier/fp8-inference","permalink":"/09-evaluation-frontier/fp8-inference","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":3,"frontMatter":{"sidebar_position":3},"sidebar":"tutorialSidebar","previous":{"title":"Speculative Decoding","permalink":"/09-evaluation-frontier/speculative-decoding"},"next":{"title":"前沿技术评估流程","permalink":"/09-evaluation-frontier/frontier-eval-process"}},{"id":"09-evaluation-frontier/frontier-eval-process","title":"前沿技术评估流程","description":"用系统化的四步法评估新技术：信息收集 → 环境搭建 → 基准测试 → 业务验证，确保技术选型有据可依。","source":"@site/docs/09-evaluation-frontier/frontier-eval-process.md","sourceDirName":"09-evaluation-frontier","slug":"/09-evaluation-frontier/frontier-eval-process","permalink":"/09-evaluation-frontier/frontier-eval-process","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":4,"frontMatter":{"sidebar_position":4},"sidebar":"tutorialSidebar","previous":{"title":"FP8 推理","permalink":"/09-evaluation-frontier/fp8-inference"},"next":{"title":"开源项目深度解读","permalink":"/17-open-source-deep-dive/"}},{"id":"09-evaluation-frontier/frontier-overview","title":"前沿技术概述","description":"掌握推理加速前沿技术（Speculative Decoding、FP8、KV Cache Compression 等），在面试中展现技术深度和前瞻性。","source":"@site/docs/09-evaluation-frontier/frontier-overview.md","sourceDirName":"09-evaluation-frontier","slug":"/09-evaluation-frontier/frontier-overview","permalink":"/09-evaluation-frontier/frontier-overview","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"